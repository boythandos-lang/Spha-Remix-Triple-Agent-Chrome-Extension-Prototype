{
  "manifest_version": 3,
  "name": "Triple-Agent Chrome Extension",
  "version": "1.0.0",
  "description": "A Chrome Extension prototype featuring a triple-agent system: Blue, RED, and Black.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
